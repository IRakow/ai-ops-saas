# ===== AI OPS SAAS — ENVIRONMENT CONFIGURATION =====

# ===== REQUIRED =====

# Supabase project
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Flask secret key (also used for credential encryption)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ===== SAAS IDENTITY =====

# Public domain where the SaaS is hosted
SAAS_DOMAIN=ops.yourdomain.com
SAAS_NAME=AI Ops

# ===== WORKSPACE =====

# Base directory for tenant git clones
WORKSPACE_BASE=/srv/ai-ops-saas/workspaces

# ===== VALOR PAYMENT SYSTEMS =====

# VALOR_API_BASE=https://api.valorpaytech.com/v1
# VALOR_API_KEY=...
# VALOR_APP_ID=...
# VALOR_WEBHOOK_SECRET=...

# ===== NOTIFICATIONS (optional) =====

# NOTIFICATION_FROM_EMAIL=ops@yourdomain.com
# SENDGRID_API_KEY=SG...
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+15551234567

# ===== GEMINI (optional, for notes analysis) =====

# GEMINI_API_KEY=...

# ===== AGENT TUNING =====

# AGENT_MODEL=claude-opus-4-6
# AGENT_TIMEOUT=1800
# POLL_INTERVAL=10

# ===== SAAS TUNING =====

# MAX_TENANTS=50
# TRIAL_DAYS=14
# DEFAULT_PLAN=trial
